{
  "name": "@alz/cesium-drawing",
  "version": "0.0.0",
  "description": "Headless drawing & measurement primitives for Cesium",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    },
    "./core": {
      "types": "./dist/core/index.d.ts",
      "import": "./dist/core/index.js",
      "require": "./dist/core/index.cjs"
    },
    "./geometry": {
      "types": "./dist/geometry/index.d.ts",
      "import": "./dist/geometry/index.js",
      "require": "./dist/geometry/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "build:watch": "tsup --watch",
    "typecheck": "tsc --noEmit",
    "test": "echo 'TODO: vitest'"
  },
  "peerDependencies": {
    "cesium": ">=1.100.0"
  },
  "devDependencies": {
    "cesium": "^1.115.0",
    "tsup": "^8.3.0",
    "typescript": "^5.4.0"
  },
  "publishConfig": {
    "access": "restricted"
  }
}
